{
  "compilerOptions": {
    "target": "ES5",
    "module": "none",
    "lib": ["ES5", "ES2015", "DOM", "DOM.Iterable", "ScriptHost"],
    "outDir": "temp/compiled",
    "rootDir": "src",
    "strict": false,
    "noImplicitAny": false,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": false,
    "sourceMap": false,
    "noEmitOnError": false
  },
  "include": [
    "src/main/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
